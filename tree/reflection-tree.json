{
  "nodes": [
    {"id": "START", "type": "start", "text": "Good evening. Let's reflect on your day."},

    {"id": "A1_Q1", "parent": "START", "type": "question",
      "text": "How would you describe your day?",
      "options": ["Productive", "Tough", "Mixed", "Frustrating"]
    },

    {"id": "A1_D1", "parent": "A1_Q1", "type": "decision",
      "rules": {
        "Productive": "A1_Q2_INT",
        "Mixed": "A1_Q2_INT",
        "Tough": "A1_Q2_EXT",
        "Frustrating": "A1_Q2_EXT"
      }
    },

    {"id": "A1_Q2_INT", "parent": "A1_D1", "type": "question",
      "text": "What made things work?",
      "options": ["My effort", "Team support", "Luck", "Adaptation"],
      "signal": "axis1:internal"
    },

    {"id": "A1_Q2_EXT", "parent": "A1_D1", "type": "question",
      "text": "When things failed, what did you feel?",
      "options": ["Out of control", "Waiting on others", "Blocked", "Stuck"],
      "signal": "axis1:external"
    },

    {"id": "A1_R1", "parent": "A1_Q2_INT", "type": "reflection",
      "text": "You saw your role in outcomes. That shows agency.",
      "signal": "axis1:internal"
    },

    {"id": "A1_R2", "parent": "A1_Q2_EXT", "type": "reflection",
      "text": "It felt external, but there was still a choice you made.",
      "signal": "axis1:external"
    },

    {"id": "BRIDGE_1_2", "parent": "A1_R1", "type": "bridge",
      "text": "Now let’s shift to what you contributed.",
      "target": "A2_Q1"
    },

    {"id": "BRIDGE_1_2B", "parent": "A1_R2", "type": "bridge",
      "text": "Now let’s shift to what you contributed.",
      "target": "A2_Q1"
    },

    {"id": "A2_Q1", "type": "question",
      "text": "What describes your interaction today?",
      "options": ["Helped someone", "Did extra work", "Expected recognition", "Felt ignored"]
    },

    {"id": "A2_D1", "parent": "A2_Q1", "type": "decision",
      "rules": {
        "Helped someone": "A2_R1",
        "Did extra work": "A2_R1",
        "Expected recognition": "A2_R2",
        "Felt ignored": "A2_R2"
      }
    },

    {"id": "A2_R1", "parent": "A2_D1", "type": "reflection",
      "text": "You focused on contribution. That builds trust.",
      "signal": "axis2:contribution"
    },

    {"id": "A2_R2", "parent": "A2_D1", "type": "reflection",
      "text": "You focused on what you deserved. Notice that pattern.",
      "signal": "axis2:entitlement"
    },

    {"id": "BRIDGE_2_3", "parent": "A2_R1", "type": "bridge",
      "text": "Now let’s expand your perspective.",
      "target": "A3_Q1"
    },

    {"id": "BRIDGE_2_3B", "parent": "A2_R2", "type": "bridge",
      "text": "Now let’s expand your perspective.",
      "target": "A3_Q1"
    },

    {"id": "A3_Q1", "type": "question",
      "text": "Who was most affected by your day?",
      "options": ["Only me", "My team", "One colleague", "Customer"]
    },

    {"id": "A3_D1", "parent": "A3_Q1", "type": "decision",
      "rules": {
        "Only me": "A3_R1",
        "My team": "A3_R2",
        "One colleague": "A3_R3",
        "Customer": "A3_R4"
      }
    },

    {"id": "A3_R1", "parent": "A3_D1", "type": "reflection",
      "text": "You focused on yourself. Try widening your lens.",
      "signal": "axis3:self"
    },

    {"id": "A3_R2", "parent": "A3_D1", "type": "reflection",
      "text": "You considered your team. That builds alignment.",
      "signal": "axis3:team"
    },

    {"id": "A3_R3", "parent": "A3_D1", "type": "reflection",
      "text": "You noticed others’ struggles. That shows empathy.",
      "signal": "axis3:empathy"
    },

    {"id": "A3_R4", "parent": "A3_D1", "type": "reflection",
      "text": "You focused on the bigger purpose. That’s impact thinking.",
      "signal": "axis3:impact"
    },

    {"id": "SUMMARY", "parent": "A3_R1", "type": "summary",
      "text": "You showed patterns across agency, contribution, and perspective today."
    },

    {"id": "END", "parent": "SUMMARY", "type": "end",
      "text": "See you tomorrow."
    }
  ]
}
